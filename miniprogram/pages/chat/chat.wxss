/* 年轻人社交微信小程序 - 聊天页面样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0;
}

/* 顶部导航栏 */
.chat-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.back-btn {
  margin-right: 30rpx;
}

.back-icon {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

.user-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid white;
}

.user-name {
  font-size: 32rpx;
  color: white;
  font-weight: bold;
}

.countdown {
  background: #FF69B4;
  color: white;
  padding: 10rpx 30rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 聊天消息区域 */
.chat-messages {
  flex: 1;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FFF5E1 0%, #FFE4B5 50%, #FFD700 100%);
}

.message-item {
  margin-bottom: 30rpx;
}

.message {
  display: flex;
  align-items: flex-end;
}

.message.right {
  justify-content: flex-end;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.message.right .message-avatar {
  margin-left: 20rpx;
  margin-right: 0;
  order: 2;
}

.message-content {
  max-width: 60%;
}

.message-bubble {
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
}

.message-bubble.left {
  border-bottom-left-radius: 5rpx;
}

.message-bubble.right {
  background: #FFD700;
  color: #000;
  border-bottom-right-radius: 5rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.message-time {
  font-size: 20rpx;
  color: #999;
}

.message.right .message-time {
  text-align: right;
}

/* 聊天输入区域 */
.chat-input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.input-wrapper {
  flex: 1;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 15rpx 30rpx;
  margin-right: 20rpx;
}

.chat-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.5;
}

.send-btn {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 15rpx 30rpx;
  box-shadow: 0 5rpx 15rpx rgba(255, 215, 0, 0.3);
}

.send-btn:active {
  transform: scale(0.95);
}

/* 聊天结束区域 */
.chat-ended {
  padding: 60rpx 40rpx;
  text-align: center;
  margin: 40rpx 30rpx;
}

.ended-title {
  font-size: 36rpx;
  color: #FF69B4;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.ended-tips {
  margin-bottom: 40rpx;
}

.ended-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.ended-buttons {
  display: flex;
  gap: 20rpx;
}

.add-friend-btn, .back-btn {
  flex: 1;
  font-size: 28rpx;
}
