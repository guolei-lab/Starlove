/* chat.wxss - 聊天页面样式 v3.0 */
page {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE6F2 50%, #FFD1E3 100%);
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

/* 聊天容器 */
.chat-container {
  flex: 1;
  position: relative;
  padding: 20rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  min-height: 0;
  overflow-y: auto;
}

/* 倒计时水印背景 */
.countdown-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  pointer-events: none;
  z-index: 0;
  opacity: 0.3;
}

.countdown-text {
  font-size: 200rpx;
  font-weight: bold;
  color: #FF69B4;
  line-height: 1;
}

.countdown-label {
  font-size: 32rpx;
  color: #333;
  display: block;
}

/* 消息列表 */
.messages-list {
  position: relative;
  z-index: 1;
  padding-bottom: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-end;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.message-avatar.avatar {
  border-radius: 50%;
}

.message-avatar.self {
  order: 2;
  margin-left: 20rpx;
}

.message-avatar.other {
  margin-right: 20rpx;
}

.message-content {
  max-width: 70%;
  padding: 24rpx 30rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  line-height: 1.5;
  position: relative;
}

.message-content.self {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.message-content.other {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  margin-top: 100rpx;
  padding: 60rpx 20rpx;
}

.text-muted {
  color: #999;
  font-size: 28rpx;
  line-height: 1.8;
}

/* 底部输入框 */
.input-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  position: sticky;
  bottom: 0;
}

.message-input {
  flex-grow: 1;
  min-height: 80rpx;
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 60rpx;
  font-size: 32rpx;
}

.send-btn {
  flex-shrink: 0;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 60rpx;
  line-height: 1;
}

/* 添加好友卡片 - 倒计时结束后显示 */
.add-friend-card {
  padding: 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.add-friend-card .tip-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.add-friend-card .tip-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.add-friend-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 60rpx;
  line-height: 1;
  font-weight: bold;
}

.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.avatar {
  border-radius: 50%;
}
