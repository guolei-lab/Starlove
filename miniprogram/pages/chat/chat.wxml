<!-- 年轻人社交微信小程序 - 聊天页面 -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="chat-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="user-info">
      <image class="user-avatar" src="{{matchedUser.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-name">{{matchedUser.nickName}}</view>
    </view>
    <view class="countdown">{{countdown}}s</view>
  </view>
  <view class="card" style="margin: 8rpx 16rpx; font-size: 24rpx;">
    连接状态：{{realtimeConnected ? "实时连接中" : "轮询模式"}}
  </view>
  <view class="card" style="margin: 16rpx;">
    <button class="back-btn" bindtap="reportUser">举报</button>
    <button class="back-btn" bindtap="blockUser">拉黑</button>
  </view>

  <!-- 聊天消息区域 -->
  <scroll-view class="chat-messages" scroll-y scroll-into-view="{{scrollToId}}">
    <view class="message-item" wx:for="{{messages}}" wx:key="id" id="message-{{index}}">
      <view class="message {{item.isSelf ? 'right' : 'left'}}">
        <image class="message-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="message-content">
          <view class="message-bubble {{item.isSelf ? 'right' : 'left'}}">
            <text class="message-text" wx:if="{{item.msgType === 'text'}}">{{item.text}}</text>
            <image
              wx:if="{{item.msgType === 'image' && item.reviewStatus !== 'rejected'}}"
              src="{{item.mediaUrl}}"
              mode="widthFix"
              style="max-width: 360rpx; border-radius: 12rpx;"
            ></image>
            <text class="message-text" wx:if="{{item.msgType === 'image' && item.reviewStatus === 'pending'}}">[图片审核中]</text>
            <text class="message-text" wx:if="{{item.msgType === 'image' && item.reviewStatus === 'rejected'}}">[图片未通过审核]</text>
          </view>
          <view class="message-time">{{item.time}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 聊天输入区域 -->
  <view class="chat-input-area" wx:if="{{!chatEnded}}">
    <view class="input-wrapper">
      <input class="chat-input" placeholder="说点什么..." value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage"></input>
    </view>
    <button class="send-btn" bindtap="sendImage">图片</button>
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>

  <!-- 聊天结束区域 -->
  <view class="chat-ended card" wx:if="{{chatEnded}}">
    <view class="ended-title">💬 聊天时间已结束</view>
    <view class="ended-tips">
      <view class="ended-tip">和对方聊得怎么样？</view>
      <view class="ended-tip">可以添加对方为好友哦！</view>
    </view>
    <view class="ended-buttons">
      <button class="btn-warm add-friend-btn" bindtap="addFriend" disabled="{{friendRequestSent}}">
        {{friendRequestSent ? "已发送好友申请" : "发送好友申请"}}
      </button>
      <button class="btn-warm back-btn" bindtap="goBack">返回首页</button>
    </view>
    <view wx:if="{{showEndBannerAd}}">
      <ad unit-id="{{adSlots.chatEndBanner}}" ad-type="banner" ad-theme="white"></ad>
    </view>
  </view>
</view>
