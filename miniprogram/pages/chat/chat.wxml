<!-- chat.wxml - 聊天页面 v3.0 优化设计 -->
<view class="container">
  <!-- 顶部信息栏 - 永远显示昵称 + 推荐话题（倒计时只是背景，顶部不变） -->
  <view class="user-info-bar card-blur">
    <view class="user-name">{{friend.nickName}}</view>
    <view class="hot-topics">
      <view 
        wx:for="{{recommendTopics}}" 
        wx:key="index"
        class="topic-tag"
        bindtap="selectTopic"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 聊天区域 - 倒计时水印背景 占满中间整个区域（就是你红框标出来的位置） -->
  <view class="chat-container">
    <!-- 大号倒计时一直显示在这里，不管是否结束，放在整个聊天区域正中间 -->
    <view class="countdown-bg">
      <text class="countdown-text">{{countdown}}s</text>
      <text class="countdown-label">聊天倒计时</text>
    </view>

    <!-- 消息列表在倒计时上层 -->
    <view class="messages-list">
      <view 
        wx:for="{{messages}}" 
        wx:key="_id" 
        class="message-item {{item.isSelf ? 'self' : 'other'}}"
      >
        <view class="message-avatar {{item.isSelf ? 'self' : 'other'}}">
          <image class="avatar" src="{{item.isSelf ? userInfo.avatarUrl : friend.avatarUrl}}" mode="aspectFill"></image>
        </view>
        <view class="message-content {{item.isSelf ? 'self' : 'other'}}">
          {{item.content}}
        </view>
      </view>
    </view>

    <!-- 空消息提示 -->
    <view wx:if="{{messages.length === 0 && !isLoading}}" class="empty-state text-center">
      <text class="text-muted">开始聊天吧~ 点击上方话题可以快速发送</text>
    </view>
  </view>

  <!-- 底部：聊天未结束显示输入框，已结束显示添加好友卡片 -->
  <view wx:if="{{!isChatEnded}}" class="input-container">
    <input 
      class="message-input"
      placeholder="输入消息..." 
      value="{{inputValue}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="sendMessage"
      maxlength="200"
    />
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>

  <!-- 聊天结束后：输入框消失，显示添加好友卡片 -->
  <view wx:else class="add-friend-card">
    <view class="tip-text">聊天倒计时已结束</view>
    <view class="tip-desc">聊得开心的话，添加好友继续聊吧</view>
    <button class="add-friend-btn" bindtap="addFriend">添加好友 {{friend.nickName}}</button>
  </view>
</view>
