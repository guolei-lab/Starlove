<!-- matching.wxml - 匹配中页面 v4.0 按照设计图重新设计 -->
<view class="container">
  <!-- 渐变背景 -->
  <view class="bg-gradient"></view>

  <!-- 内容区 -->
  <view class="content">
    <!-- 顶部圆形头像 -->
    <view class="avatar-circle">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </view>

    <!-- Tips文字 -->
    <view class="tips-box">
      <text class="tips-text">{{tipsText}}</text>
    </view>

    <!-- 标题 -->
    <text class="main-title">{{mainTitle}}</text>

    <!-- 排队信息 -->
    <view wx:if="{{queuePosition > 0}}" class="queue-info">
      <text>当前位于第 </text>
      <text class="queue-position">{{queuePosition}}</text>
      <text> 位</text>
    </view>

    <!-- 加速匹配按钮 -->
    <button wx:if="{{queuePosition > 1}}" class="btn-accelerate" bindtap="showAccelerateModal">
      加速匹配
    </button>

    <!-- Plus会员卡片 -->
    <view class="plus-card" bindtap="goPlus">
      <view class="plus-icon">
        <text>👑</text>
      </view>
      <view class="plus-text">
        <text class="plus-title">解锁Plus 免费领钻石</text>
        <text class="plus-desc">开通Plus后，免费领钻石，无限匹配，加好友</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 位置卡 -->
    <view class="item-card">
      <view class="item-header">
        <text class="item-title location">位置卡</text>
        <text class="item-location-icon">📍</text>
      </view>
      <text class="item-desc">选择想匹配的地区，不成功直接退还</text>
      <view class="item-footer">
        <view class="item-price">
          <text>💎</text>
          <text class="price-text"> 10</text>
        </view>
        <button class="btn-item-btn" bindtap="selectLocation">选择地区</button>
        <button class="btn-item-btn primary" bindtap="useLocationCard">立即使用</button>
      </view>
    </view>

    <!-- 年龄卡 -->
    <view class="item-card">
      <view class="item-header">
        <text class="item-title age">年龄卡</text>
        <text class="item-age-icon">🗓️</text>
      </view>
      <text class="item-desc">选择想匹配的年龄，不成功直接退还</text>
      <view class="item-footer">
        <view class="item-price">
          <text>💎</text>
          <text class="price-text"> 5</text>
        </view>
        <button class="btn-item-btn" bindtap="selectAge">{{selectedAgeText}}</button>
        <button class="btn-item-btn primary" bindtap="useAgeCard">立即使用</button>
      </view>
    </view>
  </view>

  <!-- 加速弹窗 - 需要加速 -->
  <view wx:if="{{showAccelerateModal}}" class="modal-overlay" bindtap="hideAccelerateModal">
    <view class="modal-card" catchtap="stopPropagation">
      <text class="modal-emoji">😥</text>
      <text class="modal-title">你前面还有较多男生排队</text>
      <text class="modal-desc">建议使用 <text class="red">5</text> 个钻石加速</text>
      <view class="modal-buttons">
        <button class="modal-btn btn-cancel" bindtap="hideAccelerateModal">再等等</button>
        <button class="modal-btn btn-confirm" bindtap="doAccelerate">加速匹配</button>
      </view>
    </view>
  </view>
</view>
