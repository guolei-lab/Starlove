<!-- matching.wxml - 聊天匹配页面 v2.0 -->
<view class="container">
  <view wx:if="{{isLoading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <view wx:if="{{!isLoading && matchedUser}}" class="chat-container">
    <!-- 用户信息头部 -->
    <view class="chat-header card">
      <view class="matched-user-info">
        <image class="avatar avatar-lg" src="{{matchedUser.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-info ml-20">
          <text class="user-name">{{matchedUser.nickName}}</text>
          <text class="chat-tip" wx:if="{{!isChatEnded}}">
            ⏱ {{formatTime(chatTimeLeft)}} 后聊天结束
          </text>
          <text class="chat-tip ended" wx:if="{{isChatEnded}}">
            🔚 聊天已结束
          </text>
        </view>
        <view wx:if="{{!isChatEnded}}" class="time-badge">
          {{formatTime(chatTimeLeft)}}
        </view>
      </view>
    </view>

    <!-- 兴趣标签 -->
    <view wx:if="{{matchedUser.interests && matchedUser.interests.length > 0}}" class="interests-section mt-20">
      <text wx:for="{{matchedUser.interests}}" wx:key="*this" class="tag">{{item}}</text>
    </view>

    <!-- 消息列表 -->
    <view class="messages-list mt-20">
      <view 
        wx:for="{{messages}}" 
        wx:key="id" 
        class="message-item {{item.isSelf ? 'self' : 'other'}}"
      >
        <view class="message-content {{item.isSelf ? 'self' : 'other'}}">
          {{item.content}}
        </view>
      </view>
    </view>

    <!-- 添加好友按钮 (聊天结束后显示) -->
    <view wx:if="{{isChatEnded}}" class="add-friend-section mt-20">
      <button class="btn-primary" bindtap="addFriend">
        添加 {{matchedUser.nickName}} 为好友
      </button>
    </view>

    <!-- 底部输入框 -->
    <view wx:if="{{!isChatEnded}}" class="input-container">
      <input 
        class="message-input" 
        placeholder="输入消息..." 
        value="{{inputValue}}"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="sendMessage"
        maxlength="200"
      />
      <button class="send-btn" bindtap="sendMessage">发送</button>
    </view>
  </view>
</view>
