/* matching.wxss - 匹配排队页面 v4.0 按照设计图 */
page {
  background: linear-gradient(180deg, #FFDFDF 0%, #FFEEEE 100%);
  min-height: 100vh;
}

.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.content {
  position: relative;
  z-index: 1;
  padding: 60rpx 30rpx 40rpx;
}

/* 顶部圆形头像 */
.avatar-circle {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 60rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-circle .avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

/* Tips文字 */
.tips-box {
  text-align: center;
  margin-bottom: 30rpx;
}

.tips-text {
  font-size: 36rpx;
  color: #FF7A7A;
  line-height: 1.6;
}

/* 主标题 */
.main-title {
  display: block;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #444;
  margin-bottom: 30rpx;
}

/* 排队信息 */
.queue-info {
  text-align: center;
  font-size: 36rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.queue-position {
  color: #FF4444;
  font-weight: bold;
  font-size: 40rpx;
}

/* 加速匹配按钮 */
.btn-accelerate {
  display: block;
  width: 400rpx;
  margin: 0 auto 30rpx;
  background: #fff;
  color: #444;
  border: none;
  border-radius: 60rpx;
  padding: 20rpx 0;
  font-size: 36rpx;
  line-height: 1;
}

.btn-accelerate::after {
  border: none;
}

/* Plus会员卡片 */
.plus-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #B066FE;
  color: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.plus-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.plus-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.plus-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.plus-desc {
  font-size: 28rpx;
  opacity: 0.8;
}

.plus-card .arrow {
  font-size: 40rpx;
  opacity: 0.8;
}

/* 道具卡片 - 位置卡/年龄卡 */
.item-card {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #FFE0E0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-title {
  font-size: 44rpx;
  font-weight: bold;
}

.item-title.location {
  color: #FF8866;
}

.item-title.age {
  color: #FF7799;
}

.item-location-icon,
.item-age-icon {
  font-size: 50rpx;
  opacity: 0.2;
}

.item-desc {
  font-size: 30rpx;
  color: #FF8888;
  margin-bottom: 24rpx;
}

.item-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-price {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 60rpx;
  padding: 12rpx 20rpx;
  font-size: 32rpx;
  color: #666;
}

.btn-item-btn {
  flex: 1;
  background: #fff;
  color: #333;
  border: none;
  border-radius: 60rpx;
  padding: 14rpx 0;
  font-size: 30rpx;
  line-height: 1;
}

.btn-item-btn.primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
}

.btn-item-btn::after {
  border: none;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.modal-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.modal-desc .red {
  color: #FF4444;
  font-weight: bold;
  font-size: 36rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 60rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  line-height: 1;
}

.modal-btn.btn-cancel {
  background: #fff;
  color: #666;
  border: 1rpx solid #ccc;
}

.modal-btn.btn-confirm {
  background: #FFDD00;
  color: #333;
  border: none;
  font-weight: bold;
}

.modal-btn::after {
  border: none;
}
