<!--index.wxml - 首页 v2.0-->
<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLogin}}" class="login-container text-center mt-30">
    <view class="logo-container">
      <text class="logo-text">星愿</text>
      <text class="slogan">遇见你，是最美的意外</text>
    </view>
    
    <view class="login-card card mt-30 scale-in">
      <image class="login-image" src="/images/welcome.png" mode="aspectFit"></image>
      <text class="login-title">开启你的温暖邂逅</text>
      <text class="login-desc text-muted">一键登录，认识有趣的新朋友</text>
      
      <button class="btn-primary mt-30" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
        微信授权登录
      </button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:if="{{isLogin}}" class="home-container fade-in">
    <!-- 用户信息卡片 -->
    <view class="user-card card">
      <view class="user-info flex-center">
        <image class="avatar avatar-xl" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-details ml-20">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="match-count text-muted">今日剩余匹配次数: {{matchCount}}/{{maxMatchCount}}</text>
        </view>
        <view class="flex-grow"></view>
        <button class="btn-outline" bindtap="goToProfile">我的</button>
      </view>
    </view>

    <!-- 热门话题 -->
    <view class="topics-section mt-20">
      <view class="section-title">热门话题</view>
      <view class="topics-list">
        <view wx:for="{{hotTopics}}" wx:key="id" class="topic-item card">
          <text class="topic-title">{{item.title}}</text>
          <text class="topic-count text-muted">{{item.count}} 人在聊</text>
        </view>
      </view>
    </view>

    <!-- 开始匹配按钮 -->
    <view class="match-section mt-40 text-center">
      <button 
        class="btn-primary match-btn {{isMatching ? 'matching' : ''}}" 
        bindtap="startMatch"
        disabled="{{isMatching}}"
      >
        {{isMatching ? '匹配中...' : '开始匹配'}}
      </button>
      <text wx:if="{{matchCount <= 5 && matchCount > 0}}" class="match-tip text-muted">
        剩余次数不多啦，看完广告可以获得更多次数哦
      </text>
      <text wx:if="{{matchCount <= 0}}" class="match-tip text-muted">
        今日次数已用完，观看广告增加次数
      </text>
    </view>
  </view>
</view>
