<!--index.wxml - 首页 v4.1 按照设计图重新设计 - 星愿 三分钟假装情侣 -->
<view class="container">
  <!-- 渐变粉色背景 -->
  <view class="bg-gradient"></view>

  <!-- 未登录状态 -->
  <view wx:if="{{!isLogin}}" class="login-container text-center">
    <view class="logo-container">
      <text class="logo-text">星愿</text>
      <text class="slogan">遇见你，是最美的意外</text>
    </view>
    
    <view class="login-card card-blur mt-40">
      <image class="login-image" src="/images/welcome.png" mode="aspectFit"></image>
      <text class="login-title">开启温暖邂逅</text>
      <text class="login-desc text-muted">找到那个懂你的TA，开始三分钟假装情侣</text>
      
      <button class="btn-primary btn-lg mt-40" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
        一键登录 · 生成专属头像
      </button>
    </view>
  </view>

  <!-- 已登录状态 - 完全按照设计图 -->
  <view wx:if="{{isLogin}}" class="home-container">
    <!-- 顶部Banner标题 - 完全按照设计图 -->
    <view class="top-banner">
      <text class="tag">💖三分钟</text>
      <text class="main-title">假装情侣</text>
      <view class="deco">
        <text class="deco-hand">👉👈</text>
        <text class="deco-heart">💘</text>
      </view>
    </view>

    <!-- Banner占位区域 - 和设计图一致的浅粉色圆角矩形 -->
    <view class="banner-placeholder">
      <!-- 这里放Banner图，设计图里就是粉色占位 -->
    </view>

    <!-- 筛选条件栏 - 和设计图完全一致 -->
    <view class="filter-bar">
      <view class="filter-item">
        <text>{{genderText}}</text>
        <text class="arrow">⇒</text>
      </view>
      <view class="filter-item">
        <text>{{ageText}}</text>
        <text class="arrow">⇩</text>
      </view>
      <view class="filter-item">
        <text>{{distanceText}}</text>
        <text class="arrow">⇩</text>
      </view>
    </view>

    <!-- 开始匹配卡片 - 和设计图完全一致 -->
    <view class="match-card">
      <view class="match-btn-wrap">
        <button class="btn-start-match" bindtap="startMatch" disabled="{{isMatching}}">
          <text class="btn-start-text">{{isMatching ? '匹配中...' : '点击开始匹配'}}</text>
        </button>
      </view>
      <text class="match-count-text">今日剩余{{matchCount}}次机会</text>
      
      <!-- 加速匹配开关 -->
      <view class="accelerate-row">
        <text class="accelerate-text">加速匹配</text>
        <switch class="accelerate-switch" checked="{{accelerateMatch}}" bindchange="onAccelerateChange" />
      </view>
    </view>

    <!-- 功能卡片：语音匹配 / 速配好友 -->
    <view class="func-cards">
      <view class="func-card left" bindtap="goVoiceMatch">
        <text class="func-title voice">语音匹配</text>
        <text class="func-desc">3分钟语音通话<text class="br"/>找对象</text>
        <text class="func-icon voice">📞</text>
      </view>
      <view class="func-card right" bindtap="goFastMatch">
        <text class="func-title fast">速配好友</text>
        <text class="func-desc">{{pendingMatchCount}}位好友待添加</text>
        <text class="func-icon fast">👥</text>
      </view>
    </view>
  </view>
</view>
