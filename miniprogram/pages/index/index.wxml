<!-- 年轻人社交微信小程序 - 首页 -->
<view class="container">
  <!-- 标题区域 -->
  <view class="header">
    <view class="title">温暖社交</view>
    <view class="subtitle">遇见你，是最美的意外</view>
  </view>

  <!-- 用户登录区域 -->
  <view class="login-section card" wx:if="{{!isLogin}}">
    <view class="text">开启你的温暖社交之旅</view>
    <button class="btn-warm login-btn" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
      <text class="btn-text">微信授权登录</text>
    </button>
  </view>

  <!-- 匹配区域 -->
  <view class="match-section card" wx:if="{{isLogin}}">
    <view class="match-info">
      <view class="match-count">
        <text class="count-number">{{matchCount}}</text>
        <text class="count-text">/ {{maxMatchCount}}</text>
      </view>
      <view class="match-label">今日匹配次数</view>
    </view>

    <!-- 匹配按钮 -->
    <button class="btn-warm match-btn" bindtap="startMatch" disabled="{{isMatching}}">
      <text wx:if="{{!isMatching}}">
        {{matchCount > 0 ? '开始匹配' : '观看广告增加次数'}}
      </text>
      <text wx:if="{{isMatching}}">
        <view class="loading-spinner"></view>
        匹配中...
      </text>
    </button>

    <!-- 广告位 -->
    <view class="ad-container" wx:if="{{matchCount <= 0}}">
      <view class="ad-text">免费匹配次数用完了？</view>
      <button class="ad-btn" bindtap="showAd">观看广告 +1 次</button>
    </view>

    <!-- 匹配规则说明 -->
    <view class="match-rules">
      <view class="rule-item">
        <text class="rule-icon">💬</text>
        <text class="rule-text">支持在线聊天3分钟</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🤝</text>
        <text class="rule-text">聊天结束后可添加好友</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🎥</text>
        <text class="rule-text">观看广告增加匹配次数</text>
      </view>
    </view>
  </view>

  <!-- 热门话题 -->
  <view class="hot-topics card" wx:if="{{isLogin}}">
    <view class="section-title">热门话题</view>
    <view class="topic-list">
      <view class="topic-item" wx:for="{{hotTopics}}" wx:key="id">
        <text class="topic-text">{{item.title}}</text>
        <text class="topic-count">{{item.count}}人参与</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{showBannerAd}}">
    <ad unit-id="{{adSlots.indexBanner}}" ad-type="banner" ad-theme="white"></ad>
  </view>

  <!-- 底部导航 -->
  <view class="footer">
    <view class="footer-item" bindtap="goToProfile">
      <text class="footer-icon">👤</text>
      <text class="footer-text">个人中心</text>
    </view>
  </view>
</view>
