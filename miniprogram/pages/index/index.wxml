<!--index.wxml - 首页 v3.1 修复标签-->
<view class="container">
  <!-- 浪漫渐变背景 -->
  <view class="bg-gradient"></view>
  
  <!-- 未登录状态 -->
  <view wx:if="{{!isLogin}}" class="login-container text-center">
    <view class="logo-container">
      <text class="logo-text">星愿</text>
      <text class="slogan">遇见你，是最美的意外</text>
    </view>
    
    <view class="login-card card-blur mt-40">
      <image class="login-image" src="/images/welcome.png" mode="aspectFit"></image>
      <text class="login-title">开启温暖邂逅</text>
      <text class="login-desc text-muted">找到那个懂你的TA，开始亲密聊天</text>
      
      <button class="btn-primary btn-lg mt-40" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
        一键登录 · 生成专属头像
      </button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:if="{{isLogin}}" class="home-container">
    <!-- 顶部Banner图片 -->
    <view class="banner-container">
      <image class="banner-image" src="https://picsum.photos/id/64/600/300" mode="aspectFill"></image>
    </view>
    <!-- 欢迎卡片 - 只保留次数和按钮 -->
    <view class="welcome-card card-blur mt-20">
      <view class="match-info">
        <text class="match-count">
          💘 今日剩余匹配 
          <text class="count-large count-highlight">{{matchCount}}</text>
           /{{maxMatchCount}}
        </text>
      </view>
        <button class="btn-primary btn-lg-match" bindtap="startMatch" disabled="{{isMatching}}">
          {{isMatching ? '匹配中...' : '💘 开始匹配'}}
        </button>
      </view>
    </view>

    <!-- 热门话题热榜 -->
    <view class="hot-topics-section mt-30">
      <view class="section-header">
        <text class="section-title">🔥 热门话题热议中</text>
        <text class="update-hint text-muted">{{lastUpdateText}}</text>
      </view>
      <view class="topics-list">
        <view wx:for="{{hotTopics}}" wx:key="id" class="topic-item card-blur">
          <view class="topic-rank">
            <text class="rank-text rank-{{index+1}}">{{index+1}}</text>
          </view>
          <view class="topic-info flex-grow">
            <text class="topic-title">{{item.title}}</text>
            <text class="topic-meta text-muted">{{item.count}} 人正在聊 · {{item.category}}</text>
          </view>
          <text class="arrow"></text>
        </view>
      </view>
    </view>

    <!-- 匹配提示 -->
    <view class="match-tip-section mt-30 text-center" wx:if="{{matchCount <= 5}}">
      <text wx:if="{{matchCount > 0}}" class="match-tip-text text-muted">
        剩余次数不多啦，点击按钮开始匹配
      </text>
      <text wx:if="{{matchCount <= 0}}" class="match-tip-text text-muted">
        今日次数已用完，观看广告增加匹配次数
      </text>
    </view>
</view>
