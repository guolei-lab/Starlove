/* index.wxss - 首页样式 三分钟假装情侣 v4.0 */
page {
  background: linear-gradient(180deg, #FFE8E8 0%, #FFD6E8 100%);
  min-height: 100vh;
}

.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* 未登录 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
  padding-left: 30rpx;
  padding-right: 30rpx;
}

.logo-container {
  text-align: center;
}

.logo-text {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: #888;
  font-weight: 300;
}

.login-card {
  width: 100%;
  text-align: center;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.card-blur {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.1);
}

.login-image {
  width: 480rpx;
  height: 320rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #888;
}

.btn-lg {
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  border-radius: 60rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 已登录 - 新设计 */
.home-container {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx 140rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.app-title {
  text-align: center;
  margin-bottom: 30rpx;
}

.title-main {
  display: inline-block;
  font-size: 32rpx;
  color: #666;
  background: #FFE8D2;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.title-art {
  display: inline-block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 50%, #FA709A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.title-deco1, .title-deco2 {
  display: block;
  font-size: 40rpx;
}

/* Banner图片 */
.banner-container {
  width: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.15);
  margin-bottom: 30rpx;
}

.banner-image {
  width: 100%;
  height: 360rpx;
}

/* 筛选条件栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  color: #333;
}

.filter-item .arrow {
  color: #666;
  font-size: 28rpx;
}

/* 开始匹配卡片 */
.match-card {
  background: #FF99BB;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.2);
}

.btn-start-match {
  width: 100%;
  background: #FFEEEE;
  color: #FF698C;
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 0;
  margin-bottom: 10rpx;
  line-height: 1;
}

.btn-start-match::after {
  border: none;
}

.btn-start-text {
  font-size: 64rpx;
  font-weight: bold;
  line-height: 1;
}

.match-count-text {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

/* 加速匹配开关行 */
.accelerate-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.accelerate-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.accelerate-switch {
  transform: scale(1.2);
}

/* 功能卡片 */
.func-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.func-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  position: relative;
  overflow: hidden;
}

.func-card.left {
  background: #FFE8CC;
}

.func-card.right {
  background: #D5F8E8;
}

.func-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.func-title.voice {
  color: #FF7A45;
}

.func-title.fast {
  color: #25BB6A;
}

.func-desc {
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
}

.func-desc .br {
  display: block;
}

.func-icon {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 100rpx;
  opacity: 0.2;
}

/* 底部Tab导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
}

.tab-item.active .tab-text {
  color: #FF69B4;
  font-weight: bold;
}

.tab-item.active .tab-icon {
  color: #FF69B4;
}

.tab-icon {
  font-size: 48rpx;
  color: #999;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

/* 工具类 */
.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
}

.mt-40 { margin-top: 40rpx; }
