/* index.wxss - 首页样式 亲密聊天风格 v2.1 */
page {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE6F2 50%, #FFD1E3 100%);
  min-height: 100vh;
}

.container {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top right, rgba(255, 105, 180, 0.15) 0%, transparent 50%),
              radial-gradient(circle at bottom left, rgba(255, 182, 193, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 未登录 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
}

.logo-container {
  text-align: center;
}

.logo-text {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: #888;
  font-weight: 300;
}

.login-card {
  width: 100%;
  text-align: center;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.card-blur {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.1);
}

.login-image {
  width: 480rpx;
  height: 320rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #888;
}

.btn-lg {
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  border-radius: 60rpx;
}

.btn-xl {
  padding: 32rpx 80rpx;
  font-size: 34rpx;
  border-radius: 60rpx;
}

.btn-outline-sm {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border: 1rpx solid #FF69B4;
  color: #FF69B4;
  background: transparent;
  border-radius: 30rpx;
  line-height: 1;
}

/* 已登录 */
.home-container {
  position: relative;
  z-index: 1;
  padding-top: 20rpx;
}

.banner-container {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.15);
}

.banner-container {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.15);
}

.banner-image {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
}

.welcome-card {
  padding: 50rpx 30rpx;
}

.match-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.match-title {
  font-size: 48rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.match-count {
  margin-bottom: 40rpx;
  line-height: 1.8;
}

.count-large {
  color: #FF69B4;
  font-weight: bold;
  font-size: 88rpx;
}

.count-total {
  font-size: 48rpx;
  color: #666;
}

.btn-lg-match {
  width: 80%;
  padding: 36rpx 0;
  font-size: 44rpx;
  border-radius: 60rpx;
  line-height: 1;
}

.btn-lg-match {
  width: 80%;
  padding: 32rpx 0;
  font-size: 36rpx;
  border-radius: 60rpx;
  line-height: 1;
}

.count-highlight {
  color: #FF69B4;
  font-weight: bold;
  font-size: 30rpx;
  margin: 0 6rpx;
}

/* 热门话题热榜 */
.hot-topics-section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.update-hint {
  font-size: 22rpx;
}

.topics-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.topic-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  transition: all 0.3s ease;
}

.topic-item:active {
  transform: scale(0.98);
}

.topic-rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.rank-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.rank-1 {
  background: linear-gradient(135deg, #FF416C 0%, #FF4B2B 100%);
}

.rank-2 {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.rank-3 {
  background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
}

.rank-1 ~ .rank-text,
.rank-2 ~ .rank-text,
.rank-3 ~ .rank-text {
  color: #fff;
}

.topic-item:not(:nth-child(-n+3)) .topic-rank {
  background: #f5f5f5;
}

.topic-item:not(:nth-child(-n+3)) .rank-text {
  color: #666;
}

.topic-info {
  display: flex;
  flex-direction: column;
}

.topic-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.topic-meta {
  font-size: 22rpx;
}

/* 匹配区域 */
.match-section {
  margin-top: 50rpx;
  margin-bottom: 60rpx;
}

.match-btn {
  width: 80%;
  font-size: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.3);
}

.match-btn.matching {
  opacity: 0.7;
}

.match-tip {
  margin-top: 20rpx;
}

.match-tip-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }

.ml-20 { margin-left: 20rpx; }

.flex-center {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-grow {
  flex-grow: 1;
}

.avatar {
  border-radius: 50%;
}

.avatar-xl {
  width: 96rpx;
  height: 96rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 40rpx;
  line-height: 1;
}

.match-tip-section {
  padding: 20rpx;
}

.match-tip-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}
