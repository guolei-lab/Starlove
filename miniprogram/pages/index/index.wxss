/* index.wxss - 首页样式 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  margin-top: 100rpx;
  text-align: center;
}

.logo-text {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.login-card {
  width: 100%;
  text-align: center;
}

.login-image {
  width: 400rpx;
  height: 300rpx;
  margin-bottom: 30rpx;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  margin-bottom: 30rpx;
}

.user-card {
  margin: 0;
}

.user-info {
  width: 100%;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.match-count {
  font-size: 26rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.topics-list {
  display: flex;
  flex-direction: column;
}

.topic-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 10rpx 0;
  padding: 24rpx 32rpx;
  transition: all 0.3s ease;
}

.topic-item:active {
  transform: scale(0.98);
}

.topic-title {
  font-size: 30rpx;
  color: #333;
}

.topic-count {
  font-size: 26rpx;
}

.match-section {
  margin-top: 100rpx;
}

.match-btn {
  width: 80%;
  font-size: 36rpx;
  padding: 32rpx;
}

.match-btn.matching {
  opacity: 0.7;
}

.match-tip {
  display: block;
  margin-top: 20rpx;
  line-height: 1.5;
}
