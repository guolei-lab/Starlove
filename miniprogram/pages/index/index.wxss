/* index.wxss - 首页样式 星愿三分钟假装情侣 v4.1 */
page {
  background: #FFEEEE;
  min-height: 100vh;
}

.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* 未登录 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
  padding-left: 30rpx;
  padding-right: 30rpx;
}

.logo-container {
  text-align: center;
}

.logo-text {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: #888;
  font-weight: 300;
}

.login-card {
  width: 100%;
  text-align: center;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.card-blur {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.1);
}

.login-image {
  width: 480rpx;
  height: 320rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #888;
}

.btn-lg {
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  border-radius: 60rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 已登录 - 完全按照设计图 */
.home-container {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx 40rpx;
  box-sizing: border-box;
}

/* 顶部Banner标题 - 完全匹配设计图 */
.top-banner {
  text-align: center;
  margin-bottom: 40rpx;
}

.top-banner .tag {
  display: inline-block;
  font-size: 56rpx;
  font-weight: bold;
  color: #444;
  background: #FFE8CE;
  padding: 4rpx 20rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  line-height: 1.2;
}

.top-banner .main-title {
  display: inline-block;
  font-size: 100rpx;
  font-weight: bold;
  color: #f8a5c2;
  opacity: 0.5;
  line-height: 1;
}

.top-banner .deco {
  margin-top: 20rpx;
}

.top-banner .deco-hand {
  display: block;
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.top-banner .deco-heart {
  display: block;
  font-size: 56rpx;
}

/* Banner占位区域 - 和设计图一致 */
.banner-placeholder {
  width: 100%;
  height: 400rpx;
  background: #F8D8E0;
  border-radius: 60rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 筛选条件栏 - 和设计图完全一致 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 18rpx 28rpx;
  border-radius: 60rpx;
  font-size: 40rpx;
  color: #333;
}

.filter-item .arrow {
  color: #666;
  font-size: 32rpx;
}

/* 开始匹配卡片 - 和设计图完全一致 */
.match-card {
  background: #FFA0BC;
  border-radius: 32rpx;
  padding: 30rpx 30rpx 40rpx;
  margin-bottom: 30rpx;
}

.match-btn-wrap {
  text-align: center;
  margin-bottom: 16rpx;
}

.btn-start-match {
  display: inline-block;
  width: auto;
  min-width: 60%;
  background: #FFEEEE;
  color: #F878A0;
  border: none;
  border-radius: 32rpx;
  padding: 20rpx 40rpx;
  line-height: 1;
}

.btn-start-match::after {
  border: none;
}

.btn-start-text {
  font-size: 88rpx;
  font-weight: bold;
  line-height: 1;
}

.match-count-text {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #333;
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* 加速匹配开关行 */
.accelerate-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.accelerate-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.accelerate-switch {
  transform: scale(1.4);
}

/* 功能卡片 */
.func-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.func-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  position: relative;
  overflow: hidden;
}

.func-card.left {
  background: #FFE8CC;
}

.func-card.right {
  background: #D5F8E8;
}

.func-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.func-title.voice {
  color: #FF7A45;
}

.func-title.fast {
  color: #25BB6A;
}

.func-desc {
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
}

.func-desc .br {
  display: block;
}

.func-icon {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 100rpx;
  opacity: 0.2;
}

/* 工具类 */
.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
}

.mt-40 { margin-top: 40rpx; }
