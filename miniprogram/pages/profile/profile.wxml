<!-- 年轻人社交微信小程序 - 个人中心页面 -->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-info card">
    <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="user-details">
      <view class="user-name">{{userInfo.nickName}}</view>
      <view class="user-id">ID: {{userId}}</view>
      <view class="user-match-count">
        <text class="count-label">今日匹配次数:</text>
        <text class="count-value">{{matchCount}}/{{maxMatchCount}}</text>
      </view>
    </view>
  </view>

  <view class="match-history card">
    <view class="section-title">好友申请</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{friendRequests}}" wx:key="id">
        <image class="match-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="match-details">
          <view class="match-name">{{item.name}}</view>
          <view class="match-time">{{item.time}}</view>
          <view class="match-status">{{item.status}}</view>
        </view>
        <view class="match-actions" wx:if="{{item.status === 'pending'}}">
          <button class="action-btn" bindtap="handleFriendRequest" data-id="{{item.id}}" data-decision="accept">同意</button>
          <button class="action-btn" bindtap="handleFriendRequest" data-id="{{item.id}}" data-decision="reject">拒绝</button>
        </view>
      </view>
    </view>
  </view>

  <view class="match-history card">
    <view class="section-title">我的好友</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{friends}}" wx:key="id">
        <image class="match-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="match-details">
          <view class="match-name">{{item.name}}</view>
          <view class="match-time">成为好友：{{item.time}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 匹配历史 -->
  <view class="match-history card">
    <view class="section-title">最近匹配</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{matchHistory}}" wx:key="id">
        <image class="match-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="match-details">
          <view class="match-name">{{item.name}}</view>
          <view class="match-time">{{item.time}}</view>
          <view class="match-status {{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="match-actions">
          <button class="action-btn" bindtap="viewChat" data-id="{{item.id}}">查看聊天</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="settings card">
    <view class="section-title">设置</view>
    <view class="settings-list">
      <view class="setting-item" bindtap="goToEditProfile">
        <text class="setting-icon">👤</text>
        <text class="setting-text">编辑个人资料</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="goToPrivacy">
        <text class="setting-icon">🔒</text>
        <text class="setting-text">隐私设置</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="goToFeedback">
        <text class="setting-icon">💬</text>
        <text class="setting-text">意见反馈</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="goToAbout">
        <text class="setting-icon">ℹ️</text>
        <text class="setting-text">关于我们</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="goToAdmin" wx:if="{{isAdmin}}">
        <text class="setting-icon">🛡️</text>
        <text class="setting-text">运营后台</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="logout">退出登录</button>

  <view class="card" wx:if="{{showBannerAd}}">
    <ad unit-id="{{adSlots.profileBanner}}" ad-type="banner" ad-theme="white"></ad>
  </view>
</view>
