<!-- profile.wxml - 个人中心 v2.2 -->
<view class="container">
  <!-- 用户信息头部 -->
  <view wx:if="{{userInfo}}" class="profile-header card-blur">
    <view class="user-info flex-center">
      <image class="avatar avatar-xl" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info-text ml-20">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-desc text-muted">StarLove 遇见你，是最美的意外</text>
      </view>
      <view class="flex-grow"></view>
      <button class="btn-outline-sm" bindtap="goToEditProfile">编辑资料</button>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="statistics-card card-blur mt-20">
    <view class="statistics-title">我的数据</view>
    <view class="statistics-list flex-between">
      <view class="statistics-item text-center">
        <text class="statistics-number">{{totalMatches}}</text>
        <text class="statistics-label text-muted">总匹配次数</text>
      </view>
      <view class="statistics-item text-center">
        <text class="statistics-number">{{friendsCount}}</text>
        <text class="statistics-label text-muted">好友数量</text>
      </view>
      <view class="statistics-item text-center">
        <text class="statistics-number">{{matchCount}}</text>
        <text class="statistics-label text-muted">今日剩余</text>
      </view>
    </view>
  </view>

  <!-- 最近匹配历史 -->
  <view class="matches-section mt-20" wx:if="{{recentMatches.length > 0}}">
    <view class="section-title">最近匹配</view>
    <view class="matches-list">
      <view 
        wx:for="{{recentMatches}}" 
        wx:key="_id" 
        class="match-item card-blur"
      >
        <image class="match-avatar avatar avatar-lg" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="match-info ml-20 flex-grow">
          <text class="match-name">{{item.nickName}}</text>
          <text class="match-age-gender text-muted">{{item.age}}岁 · {{item.gender}}</text>
        </view>
        <view class="match-actions">
          <button wx:if="{{!item.isFriend}}" class="btn-add-friend btn-primary-sm" bindtap="addFriendFromMatch" data-match="{{item}}">
            添加好友
          </button>
          <text wx:if="{{item.isFriend}}" class="is-friend-tag text-muted">已是好友</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 好友列表 -->
  <view class="friends-section mt-20" wx:if="{{friends.length > 0}}">
    <view class="section-title">我的好友</view>
    <view class="friends-list">
      <view 
        wx:for="{{friends}}" 
        wx:key="friend_openid" 
        class="friend-item card-blur"
        bindtap="goToChat"
        data-friend="{{item}}"
      >
        <image class="friend-avatar avatar avatar-lg" src="{{item.friend_avatar}}" mode="aspectFill"></image>
        <view class="friend-info ml-20 flex-grow">
          <text class="friend-name">{{item.friend_name}}</text>
          <text class="friend-time text-muted">添加于 {{item.create_time_fmt}}</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{friends.length === 0 && !isLoading}}" class="empty-state card-blur mt-20 text-center">
    <text class="empty-text text-muted">还没有添加好友哦<br/>去匹配认识新朋友~</text>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section mt-30 mb-40">
    <view class="menu-item card-blur" bindtap="about">
      <text class="menu-text">关于我们</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item card-blur mt-10" bindtap="logout">
      <text class="menu-text logout-text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
