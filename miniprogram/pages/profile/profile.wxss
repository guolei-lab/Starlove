/* profile.wxss - 个人中心样式 v2.1 */
page {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE6F2 50%, #FFD1E3 100%);
  min-height: 100vh;
}

.container {
  padding: 30rpx 20rpx;
}

.card-blur {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.1);
}

.profile-header {
  padding: 30rpx 24rpx;
}

.user-info-text {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
}

/* 表单样式 */
.profile-form {
  margin-top: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 140rpx;
}

.form-value {
  font-size: 28rpx;
  color: #666;
  flex-grow: 1;
  text-align: right;
  padding-right: 10rpx;
}

.form-input {
  flex-grow: 1;
  font-size: 28rpx;
  text-align: right;
  padding: 10rpx 0;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-top: 10rpx;
  box-sizing: border-box;
}

.count-hint {
  text-align: right;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.btn-block {
  width: 100%;
  border-radius: 60rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 统计 */
.statistics-card {
  padding: 30rpx 24rpx;
}

.statistics-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.statistics-list {
  display: flex;
  justify-content: space-around;
}

.statistics-item {
  flex: 1;
}

.statistics-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8rpx;
}

.statistics-label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 好友 */
.friends-section {
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin: 10rpx 0;
  transition: all 0.3s ease;
}

.friend-item:active {
  transform: scale(0.98);
}

.friend-avatar {
  margin-right: 20rpx;
  border-radius: 50%;
}

.avatar {
  border-radius: 50%;
}

.avatar-xl {
  width: 96rpx;
  height: 96rpx;
}

.avatar-lg {
  width: 80rpx;
  height: 80rpx;
}

.friend-info {
  display: flex;
  flex-direction: column;
}

.friend-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.friend-time {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

.empty-state {
  padding: 60rpx 20rpx;
}

.empty-text {
  line-height: 1.8;
  font-size: 28rpx;
  color: #999;
}

/* 菜单 */
.menu-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  margin: 0;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.logout-text {
  color: #ff4d4f;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }

.ml-20 { margin-left: 20rpx; }

.flex-center {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-grow {
  flex-grow: 1;
}
