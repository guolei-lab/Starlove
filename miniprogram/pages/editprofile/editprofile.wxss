/* editprofile.wxss - 编辑个人资料样式 */
page {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE6F2 50%, #FFD1E3 100%);
  min-height: 100vh;
}

.container {
  padding: 30rpx 20rpx;
}

.card-blur {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.1);
  padding: 40rpx 30rpx;
}

.avatar-section {
  margin-bottom: 30rpx;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  border: 4rpx solid #FF69B4;
}

.avatar-hint {
  font-size: 24rpx;
}

/* 表单 */
.edit-form {
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  width: 160rpx;
}

.form-value {
  font-size: 28rpx;
  color: #666;
  flex-grow: 1;
  text-align: right;
  padding-right: 10rpx;
}

.form-input {
  flex-grow: 1;
  font-size: 28rpx;
  text-align: right;
  padding: 10rpx 0;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  padding: 20rpx 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
}

.count-hint {
  text-align: right;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.btn-block {
  width: 100%;
  border-radius: 60rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
}

.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }

.arrow {
  color: #ccc;
  font-size: 32rpx;
}
