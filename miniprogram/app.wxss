/* 年轻人社交微信小程序 - 全局样式 */
page {
  background: linear-gradient(135deg, #FFF5E1 0%, #FFE4B5 50%, #FFD700 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #333;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 温暖的按钮样式 */
.btn-warm {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(255, 215, 0, 0.4);
  transition: all 0.3s ease;
}

.btn-warm:active {
  transform: scale(0.95);
  box-shadow: 0 5rpx 15rpx rgba(255, 215, 0, 0.3);
}

.btn-warm:disabled {
  opacity: 0.6;
  background: #ccc;
  box-shadow: none;
  transform: none;
}

/* 卡片样式 */
.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

/* 文字样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF69B4;
  text-align: center;
  margin-bottom: 20rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.subtitle {
  font-size: 28rpx;
  color: #FF8C00;
  text-align: center;
  margin-bottom: 30rpx;
}

.text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 215, 0, 0.3);
  border-top: 6rpx solid #FFD700;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 匹配动画 */
.match-animation {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  margin: 50rpx 0;
}

.match-heart {
  width: 100rpx;
  height: 100rpx;
  background: #FF69B4;
  position: relative;
  transform: rotate(45deg);
  animation: pulse 1.5s ease-in-out infinite;
}

.match-heart::before,
.match-heart::after {
  content: '';
  width: 100rpx;
  height: 100rpx;
  background: #FF69B4;
  border-radius: 50%;
  position: absolute;
}

.match-heart::before {
  left: -50rpx;
}

.match-heart::after {
  top: -50rpx;
}

@keyframes pulse {
  0%, 100% {
    transform: rotate(45deg) scale(1);
    opacity: 1;
  }
  50% {
    transform: rotate(45deg) scale(1.3);
    opacity: 0.8;
  }
}

/* 广告位样式 */
.ad-container {
  background: rgba(255, 215, 0, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  text-align: center;
}

.ad-text {
  font-size: 24rpx;
  color: #FF8C00;
  margin-bottom: 10rpx;
}

.ad-btn {
  background: #FF69B4;
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 5rpx 15rpx rgba(255, 105, 180, 0.3);
  transition: all 0.3s ease;
}

.ad-btn:active {
  transform: scale(0.95);
}

/* 聊天气泡 */
.chat-bubble {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.chat-bubble.left {
  background: #E5E5EA;
  color: #000;
  margin-right: auto;
  border-bottom-left-radius: 5rpx;
}

.chat-bubble.right {
  background: #FFD700;
  color: #000;
  margin-left: auto;
  border-bottom-right-radius: 5rpx;
}

/* 倒计时样式 */
.countdown {
  background: #FF69B4;
  color: white;
  padding: 15rpx 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 5rpx 15rpx rgba(255, 105, 180, 0.3);
}

/* 悬浮按钮 */
.floating-btn {
  position: fixed;
  bottom: 60rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FFD700;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(255, 215, 0, 0.5);
  font-size: 40rpx;
  z-index: 1000;
}
